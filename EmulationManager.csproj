<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <AssemblyName>EmulationManager</AssemblyName>
    <RootNamespace>EmulationManager</RootNamespace>

    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>

    <Version>0.1.0</Version>
    <Authors>Emulation Manager Contributors</Authors>
    <Description>
      A Windows game-library and emulator launcher designed for Steam integration.
    </Description>
  </PropertyGroup>

</Project>
